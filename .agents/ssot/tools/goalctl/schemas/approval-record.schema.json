{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "xhyper://goalctl/schemas/approval-record.schema.json",
  "title": "ApprovalRecord",
  "description": "批准事实（D04）。Markdown Status: Approved 仅为声明，不得单独作为晋升 Authority 的证据。",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "approval_id",
    "subject_id",
    "subject_digest",
    "scope",
    "status"
  ],
  "properties": {
    "schema_version": {
      "type": "string",
      "const": "1.0.0"
    },
    "approval_id": {
      "type": "string",
      "minLength": 1
    },
    "subject_id": {
      "type": "string"
    },
    "subject_digest": {
      "type": "string",
      "description": "被批准主体 digest"
    },
    "scope": {
      "type": "array",
      "minItems": 1,
      "items": { "type": "string" }
    },
    "approvers": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["identity"],
        "properties": {
          "identity": { "type": "string" },
          "role": { "type": ["string", "null"] }
        }
      }
    },
    "approved_commit": {
      "type": ["string", "null"],
      "pattern": "^[0-9a-f]{40}$"
    },
    "approved_at": {
      "type": ["string", "null"]
    },
    "expires_at": {
      "type": ["string", "null"]
    },
    "status": {
      "type": "string",
      "enum": ["PROPOSED", "ACTIVE", "EXPIRED", "REVOKED"]
    },
    "revoked_by": {
      "type": ["string", "null"]
    },
    "notes": {
      "type": ["string", "null"]
    }
  }
}
