{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "xhyper://goalctl/schemas/cli-output.schema.json",
  "title": "goalctl CLI JSON output envelope",
  "description": "所有 goalctl --json 成功/结构化失败输出的公共外壳。诊断码见 CLI-CONTRACT。",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "command",
    "ok",
    "source_commit",
    "repository_identity",
    "diagnostics"
  ],
  "properties": {
    "schema_version": {
      "type": "string",
      "const": "1.0.0"
    },
    "command": {
      "type": "string",
      "enum": [
        "doctor",
        "index",
        "resolve",
        "artifact",
        "reconcile",
        "compile",
        "version"
      ]
    },
    "ok": {
      "type": "boolean"
    },
    "exit_code": {
      "type": "integer",
      "minimum": 0,
      "maximum": 10,
      "description": "与进程 exit code 一致；可选重复便于管道消费"
    },
    "source_commit": {
      "type": ["string", "null"],
      "pattern": "^[0-9a-f]{40}$"
    },
    "repository_identity": {
      "$ref": "repository-identity.schema.json"
    },
    "state_dir": {
      "type": ["string", "null"],
      "description": "已解析的运行态目录（仓库相对或绝对；doctor 必填）"
    },
    "config_goal_present": {
      "type": "boolean",
      "description": "true 表示发现 .config/goal；doctor 必须报告且默认视为违规"
    },
    "result": {
      "description": "命令特定载荷；结构由各命令 schema 约束",
      "type": ["object", "array", "null"]
    },
    "diagnostics": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["code", "severity", "message"],
        "properties": {
          "code": {
            "type": "string",
            "pattern": "^GC-[A-Z0-9-]+$"
          },
          "severity": {
            "type": "string",
            "enum": ["error", "warning", "info"]
          },
          "message": {
            "type": "string",
            "minLength": 1
          },
          "path": {
            "type": ["string", "null"]
          }
        }
      }
    },
    "extensions": {
      "type": "object",
      "description": "仅 operational 报告允许；安全类命令不得依赖 extensions 放行"
    }
  }
}
