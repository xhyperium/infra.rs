{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "xhyper://goalctl/schemas/repository-identity.schema.json",
  "title": "RepositoryIdentity",
  "description": "稳定仓库身份（D03）。名称仅为 alias；Fork 必须不同 identity。",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "identity_version",
    "repository_id",
    "confidence",
    "hosting"
  ],
  "properties": {
    "identity_version": {
      "type": "integer",
      "const": 1
    },
    "repository_id": {
      "type": "string",
      "minLength": 1,
      "description": "稳定 id，例如 repo:github:123456 或 repo:degraded:<digest>"
    },
    "confidence": {
      "type": "string",
      "enum": ["FULL", "DEGRADED", "UNKNOWN"]
    },
    "hosting": {
      "type": "object",
      "additionalProperties": false,
      "required": ["provider", "canonical_name"],
      "properties": {
        "provider": {
          "type": "string",
          "enum": ["github", "local", "other"]
        },
        "provider_repository_id": {
          "type": ["integer", "null"],
          "description": "GitHub numeric id；离线可为 null → confidence 不得为 FULL（发布 Evidence 场景）"
        },
        "canonical_name": {
          "type": "string",
          "description": "当前名称 alias，例如 xhyperium/infra.rs"
        }
      }
    },
    "root_commit": {
      "type": ["string", "null"],
      "pattern": "^[0-9a-f]{40}$"
    },
    "aliases": {
      "type": "array",
      "items": { "type": "string" }
    }
  }
}
