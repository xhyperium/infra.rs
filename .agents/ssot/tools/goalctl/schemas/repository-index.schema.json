{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "xhyper://goalctl/schemas/repository-index.schema.json",
  "title": "RepositoryIndex",
  "description": "goalctl index 确定性仓库索引（PR-1）。相同 commit 重复生成必须字节级一致（在 canonical JSON 规则下）。",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "source_commit",
    "modules"
  ],
  "properties": {
    "schema_version": {
      "type": "string",
      "const": "1.0.0"
    },
    "source_commit": {
      "type": "string",
      "pattern": "^[0-9a-f]{40}$"
    },
    "modules": {
      "type": "array",
      "description": "按 module 名字典序排序",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "module",
          "package_name",
          "manifest_path",
          "package_path",
          "publish",
          "layer",
          "implementation_root",
          "spec_root"
        ],
        "properties": {
          "module": { "type": "string" },
          "package_name": {
            "type": ["string", "null"],
            "description": "Cargo package name，如 xhyper-kernel；纯规格模块可为 null"
          },
          "manifest_path": {
            "type": ["string", "null"],
            "description": "仓库相对 Cargo.toml 路径"
          },
          "package_path": {
            "type": ["string", "null"]
          },
          "targets": {
            "type": "array",
            "items": { "type": "string" }
          },
          "publish": {
            "type": ["boolean", "null"]
          },
          "layer": {
            "type": "string",
            "description": "如 L0 / L1 / tools / domain"
          },
          "implementation_root": {
            "type": ["string", "null"]
          },
          "spec_root": {
            "type": ["string", "null"],
            "description": ".agents/ssot/... 路径"
          },
          "artifact_paths": {
            "type": "object",
            "additionalProperties": {
              "type": "boolean"
            },
            "description": "关键制品路径是否存在，例如 goal/spec/design"
          }
        }
      }
    }
  }
}
