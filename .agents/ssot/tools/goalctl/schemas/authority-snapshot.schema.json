{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "xhyper://goalctl/schemas/authority-snapshot.schema.json",
  "title": "AuthoritySnapshot",
  "description": "commit-bound 权威快照（PR-2 resolve）。policy 来自 docs/goal/schema/authority-policy.yaml。",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "source_commit",
    "policy_id",
    "policy_version",
    "policy_digest",
    "entries"
  ],
  "properties": {
    "schema_version": {
      "type": "string",
      "const": "1.0.0"
    },
    "source_commit": {
      "type": "string",
      "pattern": "^[0-9a-f]{40}$"
    },
    "tree_id": {
      "type": ["string", "null"],
      "pattern": "^[0-9a-f]{40}$",
      "description": "可选；有则执行视图必须与之绑定（D09）"
    },
    "policy_id": {
      "type": "string"
    },
    "policy_version": {
      "type": "string"
    },
    "policy_digest": {
      "type": "string",
      "description": "authority-policy.yaml 内容 SHA-256（hex 或 sha256: 前缀）"
    },
    "entries": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "path",
          "kind",
          "rank",
          "status",
          "blob_sha",
          "sha256"
        ],
        "properties": {
          "path": {
            "type": "string",
            "description": "仓库相对路径"
          },
          "kind": {
            "type": "string"
          },
          "rank": {
            "type": "integer",
            "minimum": 0
          },
          "status": {
            "type": "string",
            "enum": [
              "ACTIVE",
              "PROPOSED",
              "APPROVED",
              "SUPERSEDED",
              "REVOKED",
              "EXPIRED",
              "SUSPENDED",
              "UNKNOWN"
            ]
          },
          "blob_sha": {
            "type": "string",
            "pattern": "^[0-9a-f]{40}$"
          },
          "sha256": {
            "type": "string"
          },
          "scope": {
            "type": "object",
            "additionalProperties": true
          },
          "approval_refs": {
            "type": "array",
            "items": { "type": "string" }
          }
        }
      }
    },
    "conflicts": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["code", "message"],
        "properties": {
          "code": { "type": "string" },
          "message": { "type": "string" },
          "paths": {
            "type": "array",
            "items": { "type": "string" }
          }
        }
      }
    }
  }
}
