{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "xhyper://goalctl/schemas/artifact-envelope.schema.json",
  "title": "ArtifactEnvelope",
  "description": "制品 JSON Control Block。路径与 artifact_type 必须一致。文档生命周期状态与 ModuleStatus 执行完成态隔离。",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "artifact_type",
    "artifact_id",
    "module",
    "status"
  ],
  "properties": {
    "schema_version": {
      "type": "string",
      "const": "1.0.0"
    },
    "artifact_type": {
      "type": "string",
      "enum": [
        "goal",
        "spec",
        "design",
        "plan",
        "tasks",
        "prompt",
        "test",
        "review",
        "release",
        "retrospective",
        "matrix",
        "gate",
        "evidence"
      ]
    },
    "artifact_id": {
      "type": "string",
      "minLength": 1
    },
    "module": {
      "type": "string",
      "minLength": 1
    },
    "status": {
      "type": "string",
      "enum": [
        "DRAFT",
        "PROPOSED",
        "APPROVED",
        "SUPERSEDED",
        "RETIRED"
      ],
      "description": "仅文档生命周期；禁止用 COMPLETE 表示执行完成"
    },
    "subject_digest": {
      "type": ["string", "null"],
      "description": "正文或规范主体 digest，防 ID 不变内容被替换"
    },
    "source_commit": {
      "type": ["string", "null"],
      "pattern": "^[0-9a-f]{40}$"
    },
    "effective_commit": {
      "type": ["string", "null"],
      "pattern": "^[0-9a-f]{40}$"
    },
    "owner": {
      "type": ["string", "null"]
    },
    "created_at": {
      "type": ["string", "null"],
      "description": "作者提交字段，非 CLI 运行时间"
    },
    "updated_at": {
      "type": ["string", "null"],
      "description": "作者提交字段，非 CLI 运行时间"
    },
    "approval_refs": {
      "type": "array",
      "items": { "type": "string" }
    },
    "evidence_ids": {
      "type": "array",
      "items": { "type": "string" }
    },
    "gate_ids": {
      "type": "array",
      "items": {
        "type": "string",
        "pattern": "^G([0-9]|1[0-1])$"
      }
    },
    "supersedes": {
      "type": ["string", "null"]
    },
    "extensions": {
      "type": "object"
    }
  }
}
