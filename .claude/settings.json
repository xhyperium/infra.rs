{
  "hooks": {
    "PostToolUse": [
      {
        "hooks": [
          {
            "command": "nice -n 19 timeout 30 node .claude/hooks/post-tool-check.mjs",
            "type": "command"
          }
        ],
        "matcher": "Edit|Write"
      },
      {
        "hooks": [
          {
            "command": "nice -n 19 timeout 30 node .claude/hooks/edit-guard-reset.mjs",
            "type": "command"
          }
        ],
        "matcher": "Write"
      },
      {
        "description": "Link-check after markdown edits",
        "hooks": [
          {
            "command": "nice -n 19 timeout 30 node .claude/hooks/link-check.cjs",
            "type": "command"
          }
        ],
        "matcher": "Edit|Write"
      },
      {
        "description": "批量编码巡检",
        "hooks": [
          {
            "command": "nice -n 19 timeout 15 node .claude/hooks/encoding-batch-check.mjs",
            "type": "command"
          }
        ],
        "matcher": "Edit|Write"
      }
    ],
    "PreCompact": [
      {
        "hooks": [
          {
            "command": "nice -n 19 timeout 30 node .claude/hooks/pre-compact.mjs",
            "type": "command"
          }
        ],
        "matcher": ""
      }
    ],
    "PreToolUse": [
      {
        "hooks": [
          {
            "command": "nice -n 19 timeout 30 node .claude/hooks/pre-tool-check.mjs || exit 2",
            "type": "command"
          }
        ],
        "matcher": ""
      },
      {
        "hooks": [
          {
            "command": "nice -n 19 timeout 30 node .claude/hooks/edit-guard.mjs || exit 2",
            "type": "command"
          }
        ],
        "matcher": "Edit"
      },
      {
        "hooks": [
          {
            "command": "nice -n 19 timeout 30 node .claude/hooks/count-guard.mjs || exit 2",
            "type": "command"
          }
        ],
        "matcher": "Write|Edit"
      },
      {
        "hooks": [
          {
            "command": "nice -n 19 timeout 30 node .claude/hooks/encoding-check.mjs || exit 2",
            "type": "command"
          }
        ],
        "matcher": "Write|Edit"
      }
    ],
    "SessionStart": [
      {
        "hooks": [
          {
            "command": "nice -n 19 timeout 30 node .claude/hooks/session-context.mjs",
            "type": "command"
          }
        ],
        "matcher": ""
      },
      {
        "hooks": [
          {
            "command": "bd prime --stealth --readonly --hook-json",
            "type": "command"
          }
        ],
        "matcher": ""
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "command": "nice -n 19 timeout 30 node .claude/hooks/session-review.mjs",
            "type": "command"
          },
          {
            "command": "nice -n 19 timeout 30 node .claude/hooks/version-guard.mjs",
            "type": "command"
          },
          {
            "command": "nice -n 19 timeout 30 node .claude/hooks/branch-protect.mjs",
            "type": "command"
          },
          {
            "command": "nice -n 19 timeout 30 node .claude/hooks/contract-compliance-guard.mjs",
            "type": "command"
          }
        ],
        "matcher": ""
      }
    ]
  }
}
