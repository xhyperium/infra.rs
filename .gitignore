# =============================================================================
# Sensitive Data Protection — CRITICAL
# =============================================================================
# Claude Code local configurations (contain live API tokens)
.claude/*.local.json
.claude/.edit-guard-state.json
.claude/.harness-state
.claude/reviews/
.claude/loops/

# Codex local config (may contain API keys/tokens)
.codex/config.toml
.codex/hooks.json

# Copilot agent state (may contain session data)
.copilot/

# Beads sync config (may contain repo mappings/credentials)
.beads/

# =============================================================================
# Generated by Cargo
# =============================================================================
# will have compiled files and executables
debug
target

# These are backup files generated by rustfmt
**/*.rs.bk

# MSVC Windows builds of rustc generate these, which store debugging information
*.pdb

# Generated by cargo mutants
# Contains mutation testing data
**/mutants.out*/

# =============================================================================
# IDE / Editor
# =============================================================================
# JetBrains IDE
.idea/

# Visual Studio Code
.vscode/

# macOS
.DS_Store

# =============================================================================
# Environment / Secrets
# =============================================================================
# Environment variables (may contain credentials)
.env
.env.*
!.env.example
!.env.template

# Certificate / Key files
*.pem
*.key
*.crt
*.cert
*.p12
*.pfx
*.jks
*.keystore
id_rsa
id_rsa.*
*.keytab

# =============================================================================
# Build Artifacts / Logs
# =============================================================================
# Build output
dist/
build/
out/

# Logs
*.log
logs/

# Core dumps
core
*.core

# Cache directories
.cache/
*.cache

# =============================================================================
# OS Files
# =============================================================================
Thumbs.db
desktop.ini

# Beads / Dolt files (added by bd init)
.dolt/
*.db
.beads-credential-key
.beads/proxieddb/

# Local cargo target/cache (infra.rs)
.cargo/target/
.cargo/cache/
.worktrees/
.worktree/
.cargo/draft/

# =============================================================================
# Generated local status snapshots (main 可刷，不入库)
# =============================================================================
docs/status/*.local.md
docs/status/CRATES_STATUS.local.md

# =============================================================================
# Miscellaneous
# =============================================================================
.omx
.omc/
TODO.md

# =============================================================================
# Un-ignore exceptions — 防御性例外规则
# =============================================================================
# 保证关键仓库文件不被任何上层规则吞掉
!README.md
!.gitmessage